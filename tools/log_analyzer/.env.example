# OA Log Analyzer — Environment variables
# Copy this file to .env and set OA_DEPLOY_KEY before running the tool.
# Never commit the actual .env file to version control.

# Required: deployment key (minimum 16 characters, set by the deployer)
# The deployer receives this key out-of-band (not in source code).
OA_DEPLOY_KEY=replace_with_your_deploy_key_here
