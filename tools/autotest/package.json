{
  "name": "autotest",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "electron:dev": "vite --mode electron",
    "electron:build": "vue-tsc --noEmit && vite build --mode electron && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1",
    "@vicons/ionicons5": "^0.13.0",
    "naive-ui": "^2.44.1",
    "pinia": "^2.3.0",
    "playwright": "^1.50.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vue-tsc": "^2.0.0"
  },
  "build": {
    "appId": "com.autotest.app",
    "productName": "AutoTest",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "runner/**/*"
    ],
    "extraResources": [
      {
        "from": "runner",
        "to": "runner"
      }
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}