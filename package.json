{
  "name": "oa-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "app",
    "server"
  ],
  "scripts": {
    "dev:web": "yarn --cwd app dev:web",
    "dev:mp-weixin": "yarn --cwd app dev:mp-weixin",
    "preview:mp-weixin": "yarn --cwd app preview:mp-weixin",
    "build:web": "yarn --cwd app build:web",
    "build:mp-weixin": "yarn --cwd app build:mp-weixin",
    "test": "cd test && run-all.bat",
    "test:frontend": "yarn --cwd app exec vitest run --reporter=verbose",
    "test:integration": "yarn --cwd app exec vitest run --config vitest.integration.config.ts --reporter=verbose",
    "test:backend": "cd server && mvn test",
    "install:all": "yarn install",
    "dev:backend": "cd server && mvn spring-boot:run",
    "build:backend": "cd server && mvn clean package",
    "db:init": "psql -U postgres -f server/src/main/resources/db/schema.sql"
  }
}
