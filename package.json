{
  "name": "oa-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "app/h5",
    "app/mp",
    "server"
  ],
  "scripts": {
    "dev": "dotenv -e .env -- concurrently \"yarn dev:backend\" \"yarn dev:h5\" \"yarn dev:mp\"",
    "dev:h5": "wait-on tcp:8080 && nuxt dev --cwd app/h5 --dotenv ../../.env",
    "dev:mp": "wait-on tcp:8080 && cd app/mp && uni --platform mp-weixin",
    "dev:backend": "cd server && mvn spring-boot:run",
    "build": "yarn build:backend && yarn build:h5 && yarn build:mp",
    "build:h5": "nuxt build --cwd app/h5",
    "build:mp": "cd app/mp && NODE_ENV=production uni build --platform mp-weixin",
    "build:backend": "cd server && mvn clean package -DskipTests",
    "start": "java -jar server/target/backend-*.jar",
    "test:unit:h5": "yarn workspace oa-h5 test",
    "test:unit:mp": "yarn workspace oa-mp test",
    "test:integration": "cd app && npx vitest run --config mp/vitest.integration.config.ts",
    "test:e2e": "playwright test --config test/e2e/playwright.config.ts",
    "test:e2e:report": "playwright show-report test/e2e/playwright-report"
  },
  "lint-staged": {
    "*.{ts,vue,js,json}": [],
    "*.java": []
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "concurrently": "^8.2.2",
    "dotenv-cli": "^7.4.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "wait-on": "^7.2.0"
  }
}
