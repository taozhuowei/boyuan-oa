{
  "name": "oa-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "app/h5",
    "app/mp",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"yarn dev:backend\" \"yarn dev:h5\" \"yarn dev:mp\"",
    "dev:h5": "wait-on tcp:8080 && nuxt dev --cwd app/h5",
    "dev:mp": "wait-on tcp:8080 && cd app/mp && uni --platform mp-weixin",
    "dev:backend": "cd server && mvn spring-boot:run",
    "build": "yarn build:backend && yarn build:h5 && yarn build:mp",
    "build:h5": "nuxt build --cwd app/h5",
    "build:mp": "cd app/mp && NODE_ENV=production uni build --platform mp-weixin",
    "build:backend": "cd server && mvn clean package -DskipTests",
    "start": "java -jar server/target/backend-*.jar"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  }
}
