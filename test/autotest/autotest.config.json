{
  "schema_version": "2.0",
  "name": "boyuan-oa",
  "project_root": "../..",
  "preview": {
    "base_url": "http://127.0.0.1:3000",
    "entry_url": "http://127.0.0.1:3000/login",
    "healthcheck_url": "http://127.0.0.1:3000/login"
  },
  "cases": {
    "root_dir": "./cases",
    "include": [
      "**/*.ts"
    ],
    "exclude": [
      "**/_*.ts",
      "**/*.d.ts",
      "**/node_modules/**",
      "**/dist/**",
      "**/coverage/**"
    ]
  },
  "execution": {
    "concurrency": 1,
    "step_timeout": 30000,
    "screenshot_on_step": true,
    "auto_advance": true
  },
  "report": {
    "output_dir": "./reports",
    "formats": [
      "json",
      "html",
      "markdown"
    ]
  },
  "launch": {
    "commands": [
      {
        "name": "backend",
        "command": "yarn dev:backend",
        "cwd": "../..",
        "ready": {
          "type": "tcp",
          "port": 8080,
          "timeout_ms": 120000,
          "interval_ms": 1000
        }
      },
      {
        "name": "frontend",
        "command": "yarn dev:h5",
        "cwd": "../..",
        "ready": {
          "type": "http",
          "url": "http://127.0.0.1:3000/login",
          "timeout_ms": 120000,
          "interval_ms": 1000
        }
      }
    ]
  }
}
