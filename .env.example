# 环境变量模板
# 用法：复制本文件为 .env，按需填写，.env 已被 gitignore 排除。
# 注意：生产环境必须修改所有密钥类变量，禁止使用默认值。

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 端口
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SERVER_PORT=8080

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 密钥类（生产环境必填，禁止使用默认值）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# JWT 签名密钥（建议 64 位以上强随机字符串）
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_STRING_64CHARS_OR_MORE

# 电子签名 AES-256 密钥（必须为 32 字符）
APP_SIGNATURE_AES_KEY=CHANGE_ME_TO_32_CHAR_AES_KEY

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 数据库（仅生产环境）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DB_URL=jdbc:postgresql://localhost:5432/boyuan_oa
DB_USERNAME=oa
DB_PASSWORD=changeme


