# 环境变量模板
# 用法：复制本文件为 .env，按需填写，.env 已被 gitignore 排除。
# 标注 [必填-生产] 的变量在生产环境没有默认值，启动前必须设置。

# ════════════════════════════════════════════════
# 端口
# ════════════════════════════════════════════════

# 后端 HTTP 监听端口
# 用途：Spring Boot 和 Nuxt 代理共用此值，改一处全生效
# 默认值：8080
# 影响范围：后端 (application.yml) + 前端代理 (nuxt.config.ts)
# 注意：修改后需同步更新 package.json 里 wait-on 的端口号
SERVER_PORT=8080

# ════════════════════════════════════════════════
# 数据库（仅生产环境）
# ════════════════════════════════════════════════

# PostgreSQL JDBC 连接串 [必填-生产]
# 用途：后端连接生产数据库
# 默认值：开发环境使用内嵌 H2，此项不生效
# 影响范围：后端 application-prod.yml
# 示例：jdbc:postgresql://db-host:5432/boyuan_oa
DB_URL=

# 数据库用户名 [必填-生产]
# 默认值：oa（仅作占位，生产环境必须显式设置）
DB_USERNAME=

# 数据库密码 [必填-生产]
# 注意：请勿使用弱口令；建议通过密钥管理系统注入而非明文写入文件
DB_PASSWORD=

# ════════════════════════════════════════════════
# 安全密钥（仅生产环境）
# ════════════════════════════════════════════════

# JWT 签名密钥 [必填-生产]
# 用途：对 JWT 令牌进行 HMAC-SHA256 签名，防止伪造
# 默认值：开发环境使用 application.yml 中的不安全占位值，生产必须替换
# 生成命令：openssl rand -base64 64
# 注意：泄露后所有在线令牌立即失效，必须轮换并重新登录
JWT_SECRET=

# 电子签名 AES-256 加密密钥 [必填-生产]
# 用途：对员工手写签名图像进行 AES-256 加密存储
# 默认值：开发环境使用 application.yml 中的固定值，生产必须替换
# 生成命令：openssl rand -hex 32（输出 64 位十六进制，对应 32 字节）
# 注意：丢失后已加密的签名数据无法解密，请妥善备份
SIGNATURE_AES_KEY=

# ════════════════════════════════════════════════
# 文件存储
# ════════════════════════════════════════════════

# 附件上传目录（绝对路径）
# 用途：工伤照片、施工日志附件等上传文件的持久化存储位置
# 默认值：./uploads（相对于 JAR 启动目录，仅适合开发）
# 影响范围：后端 application-prod.yml；Docker 部署时需挂载对应 Volume
# 注意：生产环境务必使用绝对路径，并确保目录对运行用户可写
OA_UPLOAD_DIR=

# ════════════════════════════════════════════════
# 运维部署（仅部署脚本使用）
# ════════════════════════════════════════════════

# 部署目标服务器的 SSH 连接串
# 用途：tools/deploy/update.sh 通过 SSH 将 JAR 推送到服务器
# 示例：deploy@192.168.1.100
OA_DEPLOY_HOST=

# 服务器上的部署目录
# 用途：JAR、PID 文件、日志存放位置
# 示例：/opt/boyuan-oa
OA_DEPLOY_PATH=

# SSH 私钥路径（本机路径）
# 用途：免密登录部署服务器
# 示例：/home/user/.ssh/id_rsa_deploy
# 注意：私钥权限须为 600，且对应公钥已添加到服务器 authorized_keys
OA_DEPLOY_KEY=
