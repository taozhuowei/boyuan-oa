# 环境变量模板
# 用法：复制本文件为 .env，按需填写，.env 已被 gitignore 排除。
# 注意：生产环境必须修改所有密钥类变量，禁止使用默认值。

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 端口
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SERVER_PORT=8080

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 密钥类（生产环境必填，禁止使用默认值）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# JWT 签名密钥
JWT_SECRET=<your_jwt_secret_here>

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 数据库（仅生产环境）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DB_URL=jdbc:postgresql://<db_host>:<db_port>/<db_name>
DB_USERNAME=<your_db_user>
DB_PASSWORD=<your_db_password>
