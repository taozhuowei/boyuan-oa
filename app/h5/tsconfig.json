{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "paths": {
      "~": ["."],
      "~/*": ["./*"],
      "@": ["."],
      "@/*": ["./*"],
      "~~": ["."],
      "~~/*": ["./*"],
      "@shared": ["../shared"],
      "@shared/*": ["../shared/*"]
    }
  }
}
