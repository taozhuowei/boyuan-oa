eAAY;AAAA,wBAAG,KAAK;AAAA,wBAAI,KAAK;AAAA,wBAAI,OAAA,EAAA,SAAA,OAAA;AAAA,sBAAA;;;;;;;;;;;;;QAOvE,MAAM,cAAA;AAAA,qCAAA,cAAa,QAAA;AAAA,QAC3B,OAAM;AAAA,QACL,MAAI;AAAA,QACJ,mBAAiB,YAAA;AAAA,MAAA;yBAJpB,CAcU,GAAAL,QAAAC,UAAA,aAAA;;;cARC,OAAO,SAAA;AAAA,cAAU,QAAO;AAAA,YAAA;+BAAjC,CAOSE,IAAAH,QAAAC,UAAAG,cAAA;;;oBANM,OAAM;AAAA,oBAAO,UAAA;AAAA,kBAAA;qCAA1B,CAEcD,IAAAH,QAAAC,UAAAG,cAAA;;;0BADK,OAAO,SAAA,MAAS;AAAA,0BAAT,kBAAA,CAAA,WAAA,SAAA,MAAS,OAAI;AAAA,wBAAA;;;0BAArCC,YAAyC,oBAAA;AAAA,4BAAxB,OAAO,SAAA,MAAS;AAAA,4BAAT,kBAAA,CAAA,WAAA,SAAA,MAAS,OAAI;AAAA,0BAAA;;;;;;AAE1BL,yBAAAE,mBAAA,wBAAA,EAAA,OAAM,UAAM;AAAA,qCAAzB,CAEcC,IAAAH,QAAAC,UAAAG,cAAA;;;0BADW,OAAO,SAAA,MAAS;AAAA,0BAAT,kBAAA,CAAA,WAAA,SAAA,MAAS,eAAY;AAAA,0BAAE,OAAA,EAAA,SAAA,OAAA;AAAA,0BAAqB,gBAAa;AAAA,wBAAA;;;0BAAvFC,YAAsG,0BAAA;AAAA,4BAA/E,OAAO,SAAA,MAAS;AAAA,4BAAT,kBAAA,CAAA,WAAA,SAAA,MAAS,eAAY;AAAA,4BAAE,OAAA,EAAA,SAAA,OAAA;AAAA,4BAAqB,gBAAa;AAAA,0BAAA;;;;;;;;oBAJzFA,YAEc,wBAAA;AAAA,sBAFD,OAAM;AAAA,sBAAO,UAAA;AAAA,oBAAA;uCACxB,MAAyC;AAAA,wBAAzCA,YAAyC,oBAAA;AAAA,0BAAxB,OAAO,SAAA,MAAS;AAAA,0BAAT,kBAAA,CAAA,WAAA,SAAA,MAAS,OAAI;AAAA,wBAAA;;;;oBAEvCA,YAEc,wBAAA,EAFD,OAAM,UAAM;AAAA,uCACvB,MAAsG;AAAA,wBAAtGA,YAAsG,0BAAA;AAAA,0BAA/E,OAAO,SAAA,MAAS;AAAA,0BAAT,kBAAA,CAAA,WAAA,SAAA,MAAS,eAAY;AAAA,0BAAE,OAAA,EAAA,SAAA,OAAA;AAAA,0BAAqB,gBAAa;AAAA,wBAAA;;;;;;;;;;;cAL3FA,YAOS,mBAAA;AAAA,gBAPA,OAAO,SAAA;AAAA,gBAAU,QAAO;AAAA,cAAA;iCAC/B,MAEc;AAAA,kBAFdA,YAEc,wBAAA;AAAA,oBAFD,OAAM;AAAA,oBAAO,UAAA;AAAA,kBAAA;qCACxB,MAAyC;AAAA,sBAAzCA,YAAyC,oBAAA;AAAA,wBAAxB,OAAO,SAAA,MAAS;AAAA,wBAAT,kBAAA,CAAA,WAAA,SAAA,MAAS,OAAI;AAAA,sBAAA;;;;kBAEvCA,YAEc,wBAAA,EAFD,OAAM,UAAM;AAAA,qCACvB,MAAsG;AAAA,sBAAtGA,YAAsG,0BAAA;AAAA,wBAA/E,OAAO,SAAA,MAAS;AAAA,wBAAT,kBAAA,CAAA,WAAA,SAAA,MAAS,eAAY;AAAA,wBAAE,OAAA,EAAA,SAAA,OAAA;AAAA,wBAAqB,gBAAa;AAAA,sBAAA;;;;;;;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_push","_parent","_ssrRenderComponent","_","_scopeId","_createVNode","_ssrInterpolate","_createTextVNode","_toDisplayString","navigateTo","_createBlock","_Fragment","_withCtx"],"sources":["../../../../pages/projects/index.vue"],"sourcesContent":["<template>\n  <!-- 项目列表页\n       CEO: 可创建/编辑/关闭/删除项目\n       PM: 只看自己负责的项目（后端自动过滤）\n       其他角色: 只读查看 -->\n  <div class=\"projects-page\">\n    <div class=\"page-header\" style=\"display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;\">\n      <h2 class=\"page-title\" style=\"margin: 0;\">项目管理</h2>\n      <a-button v-if=\"isCeo\" type=\"primary\" @click=\"showCreateModal = true\">+ 新建项目</a-button>\n    </div>\n\n    <!-- 筛选栏 -->\n    <a-card style=\"margin-bottom: 12px;\">\n      <a-space>\n        <a-select\n          v-model:value=\"statusFilter\"\n          style=\"width: 140px;\"\n          placeholder=\"全部状态\"\n          allow-clear\n          @change=\"loadProjects\"\n        >\n          <a-select-option value=\"ACTIVE\">进行中</a-select-option>\n          <a-select-option value=\"CLOSED\">已关闭</a-select-option>\n        </a-select>\n        <a-button @click=\"loadProjects\" :loading=\"loading\">刷新</a-button>\n      </a-space>\n    </a-card>\n\n    <!-- 项目列表 -->\n    <a-card>\n      <a-table\n        :columns=\"columns\"\n        :data-source=\"projects\"\n        :loading=\"loading\"\n        row-key=\"id\"\n        size=\"small\"\n        :pagination=\"{ pageSize: 10, showSizeChanger: false }\"\n      >\n        <template #bodyCell=\"{ column, record }\">\n          <template v-if=\"column.key === 'name'\">\n            <a @click=\"navigateTo(`/projects/${record.id}`)\">{{ record.name }}</a>\n          </template>\n          <template v-if=\"column.key === 'status'\">\n            <a-tag :color=\"record.status === 'ACTIVE' ? 'green' : 'default'\">\n              {{ record.status === 'ACTIVE' ? '进行中' : '已关闭' }}\n            </a-tag>\n          </template>\n          <template v-if=\"column.key === 'startDate'\">\n            {{ record.startDate ?? '—' }}\n          </template>\n          <template v-if=\"column.key === 'memberCount'\">\n            {{ record.memberCount }} 人\n          </template>\n          <template v-if=\"column.key === 'action'\">\n            <a-space>\n              <a-button type=\"link\" size=\"small\" @click=\"navigateTo(`/projects/${record.id}`)\">详情</a-button>\n              <template v-if=\"isCeo\">\n                <a-button type=\"link\" size=\"small\" @click=\"openEditModal(record as ProjectItem)\">编辑</a-button>\n                <a-popconfirm\n                  v-if=\"record.status === 'ACTIVE'\"\n                  title=\"确认关闭该项目？\"\n                  @confirm=\"doCloseProject(record.id as number)\"\n                >\n                  <a-button type=\"link\" size=\"small\" danger>关闭</a-button>\n                </a-popconfirm>\n                <a-button\n                  v-if=\"record.status === 'CLOSED'\"\n                  type=\"link\"\n                  size=\"small\"\n                  @click=\"doReopenProject(record.id as number)\"\n                >重开</a-button>\n                <a-popconfirm title=\"确认删除该项目？\" @confirm=\"doDeleteProject(record.id as number)\">\n                  <a-button type=\"link\" size=\"small\" danger>删除</a-button>\n                </a-popconfirm>\n              </template>\n            </a-space>\n          </template>\n        </template>\n      </a-table>\n    </a-card>\n\n    <!-- 新建项目弹窗 -->\n    <a-modal\n      v-model:open=\"showCreateModal\"\n      title=\"新建项目\"\n      @ok=\"doCreateProject\"\n      :confirm-loading=\"createLoading\"\n      @cancel=\"resetCreateForm\"\n    >\n      <a-form :model=\"createForm\" layout=\"vertical\">\n        <a-form-item label=\"项目名称\" required>\n          <a-input v-model:value=\"createForm.name\" placeholder=\"请输入项目名称\" />\n        </a-form-item>\n        <a-form-item label=\"开始日期\">\n          <a-date-picker v-model:value=\"createForm.startDateStr\" style=\"width: 100%;\" value-format=\"YYYY-MM-DD\" />\n        </a-form-item>\n        <a-form-item label=\"日志申报周期（天）\">\n          <a-input-number v-model:value=\"createForm.logCycleDays\" :min=\"1\" :max=\"30\" style=\"width: 100%;\" />\n        </a-form-item>\n      </a-form>\n    </a-modal>\n\n    <!-- 编辑项目弹窗 -->\n    <a-modal\n      v-model:open=\"showEditModal\"\n      title=\"编辑项目\"\n      @ok=\"doUpdateProject\"\n      :confirm-loading=\"editLoading\"\n    >\n      <a-form :model=\"editForm\" layout=\"vertical\">\n        <a-form-item label=\"项目名称\" required>\n          <a-input v-model:value=\"editForm.name\" />\n        </a-form-item>\n        <a-form-item label=\"开始日期\">\n          <a-date-picker v-model:value=\"editForm.startDateStr\" style=\"width: 100%;\" value-format=\"YYYY-MM-DD\" />\n        </a-form-item>\n      </a-form>\n    </a-modal>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\n/**\n * 项目列表页 — projects/index.vue\n * 数据来源：GET /api/projects\n * CEO 可创建/编辑/关闭/删除；PM 只读（后端按 pmEmployeeId 过滤）\n */\nimport { ref, computed, onMounted } from 'vue'\nimport { request } from '~/utils/http'\nimport { useUserStore } from '~/stores/user'\nimport { message } from 'ant-design-vue'\n\ninterface ProjectItem {\n  id: number\n  name: string\n  status: string\n  startDate: string | null\n  actualEndDate: string | null\n  logCycleDays: number\n  memberCount: number\n}\n\ninterface PageResult<T> {\n  records: T[]\n  total: number\n  current: number\n  size: number\n}\n\nconst userStore = useUserStore()\nconst role = computed(() => userStore.userInfo?.role ?? '')\nconst isCeo = computed(() => role.value === 'ceo')\n\nconst loading = ref(false)\nconst projects = ref<ProjectItem[]>([])\nconst statusFilter = ref<string | undefined>(undefined)\n\n// 新建表单\nconst showCreateModal = ref(false)\nconst createLoading = ref(false)\nconst createForm = ref({ name: '', startDateStr: null as string | null, logCycleDays: 1 })\n\n// 编辑表单\nconst showEditModal = ref(false)\nconst editLoading = ref(false)\nconst editForm = ref({ id: 0, name: '', startDateStr: null as string | null })\n\nconst columns = [\n  { title: 'ID', dataIndex: 'id', key: 'id', width: 60 },\n  { title: '项目名称', dataIndex: 'name', key: 'name' },\n  { title: '状态', dataIndex: 'status', key: 'status', width: 100 },\n  { title: '开始日期', dataIndex: 'startDate', key: 'startDate', width: 120 },\n  { title: '成员数', dataIndex: 'memberCount', key: 'memberCount', width: 80 },\n  { title: '操作', key: 'action', width: 180 }\n]\n\nasync function loadProjects() {\n  loading.value = true\n  try {\n    const params: Record<string, string> = { page: '1', size: '100' }\n    if (statusFilter.value) params.status = statusFilter.value\n    const query = new URLSearchParams(params).toString()\n    const res = await request<PageResult<ProjectItem>>({ url: `/projects?${query}`, method: 'GET' })\n    projects.value = res.records ?? []\n  } catch {\n    message.error('加载项目列表失败')\n  } finally {\n    loading.value = false\n  }\n}\n\nfunction resetCreateForm() {\n  createForm.value = { name: '', startDateStr: null, logCycleDays: 1 }\n}\n\nasync function doCreateProject() {\n  if (!createForm.value.name.trim()) {\n    message.warning('项目名称不能为空')\n    return\n  }\n  createLoading.value = true\n  try {\n    const body: Record<string, unknown> = { name: createForm.value.name }\n    if (createForm.value.startDateStr) body.startDate = createForm.value.startDateStr\n    if (createForm.value.logCycleDays) body.logCycleDays = createForm.value.logCycleDays\n    await request({ url: '/projects', method: 'POST', body })\n    message.success('项目创建成功')\n    showCreateModal.value = false\n    resetCreateForm()\n    await loadProjects()\n  } catch {\n    message.error('创建失败')\n  } finally {\n    createLoading.value = false\n  }\n}\n\nfunction openEditModal(project: ProjectItem) {\n  editForm.value = { id: project.id, name: project.name, startDateStr: project.startDate }\n  showEditModal.value = true\n}\n\nasync function doUpdateProject() {\n  if (!editForm.value.name.trim()) {\n    message.warning('项目名称不能为空')\n    return\n  }\n  editLoading.value = true\n  try {\n    const body: Record<string, unknown> = { name: editForm.value.name }\n    if (editForm.value.startDateStr) body.startDate = editForm.value.startDateStr\n    await request({ url: `/projects/${editForm.value.id}`, method: 'PUT', body })\n    message.success('已更新')\n    showEditModal.value = false\n    await loadProjects()\n  } catch {\n    message.error('更新失败')\n  } finally {\n    editLoading.value = false\n  }\n}\n\nasync function doCloseProject(id: number) {\n  try {\n    await request({ url: `/projects/${id}/status`, method: 'PATCH', body: { status: 'CLOSED' } })\n    message.success('项目已关闭')\n    await loadProjects()\n  } catch {\n    message.error('操作失败')\n  }\n}\n\nasync function doReopenProject(id: number) {\n  try {\n    await request({ url: `/projects/${id}/status`, method: 'PATCH', body: { status: 'ACTIVE' } })\n    message.success('项目已重开')\n    await loadProjects()\n  } catch {\n    message.error('操作失败')\n  }\n}\n\nasync function doDeleteProject(id: number) {\n  try {\n    await request({ url: `/projects/${id}`, method: 'DELETE' })\n    message.success('已删除')\n    await loadProjects()\n  } catch {\n    message.error('删除失败')\n  }\n}\n\nonMounted(() => loadProjects())\n</script>\n"],"version":3}