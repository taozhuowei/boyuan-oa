C,UAAA,EAAA,KAAA,KAAA;AAAA,oDADN,WAAW,OAAO,UAAU,CAAA,GAAA,CAAA;AAAA,kBAAA;kBAEjB,OAAO,QAAG,yBACxBD,YAA6E,qBAAA;AAAA;oBAAnE,MAAK;AAAA,oBAAO,MAAK;AAAA,oBAAS,kFAAiB,OAAA;AAAA,kBAAA;qCAAW,MAAE;AAAA,sCAAF,IAAE;AAAA,oBAAA;;;;;;eAI5D,QAAA,SAAW,SAAA,MAAS,WAAM,kBAAtCA,YAEM,OAAA;AAAA;gBAFwC,OAAM;AAAA,cAAA,GAAY,UAEhE;;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderComponent","_push","_parent","_createVNode","_scopeId","navigateTo","_","_createBlock","_Fragment","_withCtx"],"sources":["../../../../pages/index.vue"],"sourcesContent":["<template>\n  <!-- Workbench dashboard — shows role-based summary cards and pending approval items -->\n  <div class=\"workbench-page\">\n    <h2 class=\"page-title\">工作台</h2>\n\n    <!-- KPI cards -->\n    <div class=\"stat-cards\">\n      <a-card class=\"stat-card\">\n        <a-statistic\n          title=\"待审批事项\"\n          :value=\"todoList.length\"\n          suffix=\"项\"\n        />\n      </a-card>\n      <a-card class=\"stat-card\">\n        <a-statistic title=\"通知\" :value=\"0\" suffix=\"条未读\" />\n      </a-card>\n    </div>\n\n    <!-- Pending approval items -->\n    <a-card title=\"待办事项\" class=\"section-card\">\n      <a-table\n        :columns=\"todoColumns\"\n        :data-source=\"todoList\"\n        :loading=\"loading\"\n        :pagination=\"false\"\n        row-key=\"id\"\n        size=\"small\"\n      >\n        <template #bodyCell=\"{ column, record }\">\n          <template v-if=\"column.key === 'submitTime'\">\n            {{ formatTime(record.submitTime) }}\n          </template>\n          <template v-if=\"column.key === 'action'\">\n            <a-button type=\"link\" size=\"small\" @click=\"navigateTo('/todo')\">查看</a-button>\n          </template>\n        </template>\n      </a-table>\n      <div v-if=\"!loading && todoList.length === 0\" class=\"empty-tip\">\n        暂无待办事项\n      </div>\n    </a-card>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, onMounted } from 'vue'\nimport { request } from '~/utils/http'\n\ninterface FormRecord {\n  id: number\n  formTypeName: string\n  submitter: string\n  submitTime: string\n  status: string\n  formData?: Record<string, unknown>\n}\n\nconst loading = ref(false)\nconst todoList = ref<FormRecord[]>([])\n\nconst todoColumns = [\n  { title: '类型', dataIndex: 'formTypeName', key: 'formTypeName' },\n  { title: '申请人', dataIndex: 'submitter', key: 'submitter' },\n  { title: '提交时间', key: 'submitTime' },\n  { title: '操作', key: 'action', width: 80 }\n]\n\nfunction formatTime(t: string | undefined) {\n  if (!t) return '—'\n  return t.replace('T', ' ').slice(0, 16)\n}\n\nonMounted(async () => {\n  loading.value = true\n  try {\n    const list = await request<FormRecord[]>({ url: '/attendance/todo' })\n    todoList.value = list ?? []\n  } catch {\n    todoList.value = []\n  } finally {\n    loading.value = false\n  }\n})\n</script>\n\n<style scoped>\n.workbench-page {\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n.page-title {\n  font-size: 20px;\n  font-weight: 600;\n  margin: 0 0 4px;\n  color: #003466;\n}\n\n.stat-cards {\n  display: flex;\n  gap: 16px;\n  flex-wrap: wrap;\n}\n\n.stat-card {\n  flex: 1;\n  min-width: 160px;\n}\n\n.section-card {\n  flex: 1;\n}\n\n.empty-tip {\n  text-align: center;\n  color: #999;\n  padding: 24px 0;\n}\n</style>\n"],"version":3}