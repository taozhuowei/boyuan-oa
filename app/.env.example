# Deployment host (SSH target for deployment scripts)
# Example: OA_DEPLOY_HOST=deploy@production-server
OA_DEPLOY_HOST=

# Remote deployment path on the server
# Example: OA_DEPLOY_PATH=/opt/boyuan-oa
OA_DEPLOY_PATH=

# Path to SSH private key for deployment authentication
# Example: OA_DEPLOY_KEY=/home/user/.ssh/id_rsa_deploy
OA_DEPLOY_KEY=

# PostgreSQL database JDBC URL
# Example: DB_URL=jdbc:postgresql://localhost:5432/boyuan_oa
DB_URL=

# PostgreSQL database username
# Example: DB_USERNAME=oa
DB_USERNAME=

# PostgreSQL database password
# Example: DB_PASSWORD=secure_random_password
DB_PASSWORD=

# JWT signing secret (REQUIRED - no default, must be set)
# Generate with: openssl rand -base64 64
# Example: JWT_SECRET=your-256-bit-secret-here...
JWT_SECRET=

# AES key for signature encryption (REQUIRED - no default, must be set)
# Generate with: openssl rand -hex 32
# Example: SIGNATURE_AES_KEY=your-32-byte-hex-key...
SIGNATURE_AES_KEY=

# Directory for file uploads (persistent storage)
# Example: OA_UPLOAD_DIR=/var/oa/uploads
OA_UPLOAD_DIR=

# HTTP server port (default: 8080)
# Example: SERVER_PORT=8080
SERVER_PORT=
