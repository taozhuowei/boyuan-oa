{
  "name": "oa-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:web": "yarn --cwd frontend dev:web",
    "dev:mp-weixin": "yarn --cwd frontend dev:mp-weixin",
    "preview:mp-weixin": "yarn --cwd frontend preview:mp-weixin",
    "build:web": "yarn --cwd frontend build:web",
    "build:mp-weixin": "yarn --cwd frontend build:mp-weixin",
    "install:all": "yarn --cwd frontend install",
    "dev:backend": "cd backend && mvn spring-boot:run",
    "build:backend": "cd backend && mvn clean package",
    "db:init": "psql -U postgres -f backend/src/main/resources/db/schema.sql"
  }
}
